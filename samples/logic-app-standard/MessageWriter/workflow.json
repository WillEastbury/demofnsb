{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "triggers": {
      "When_messages_are_available": {
        "type": "ServiceProvider",
        "inputs": {
          "parameters": {
            "topicName": "@appsetting('MessageTopicName')",
            "subscriptionName": "@appsetting('MessageSubscriptionName')",
            "isSessionsEnabled": false
          },
          "serviceProviderConfiguration": {
            "connectionName": "serviceBus",
            "operationId": "receiveTopicMessages",
            "serviceProviderId": "/serviceProviders/serviceBus"
          }
        },
        "splitOn": "@triggerOutputs()?['body']"
      }
    },
    "actions": {
      "Parse_message": {
        "type": "ParseJson",
        "inputs": {
          "content": "@triggerBody()?['contentData']",
          "schema": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "runAfter": {}
      },
      "Required_keys_are_present": {
        "type": "If",
        "expression": {
          "and": [
            {
              "not": {
                "equals": [
                  "@body('Parse_message')?[appsetting('MessagePartitionKeyField')]",
                  null
                ]
              }
            },
            {
              "not": {
                "equals": [
                  "@string(body('Parse_message')?[appsetting('MessagePartitionKeyField')])",
                  ""
                ]
              }
            },
            {
              "not": {
                "equals": [
                  "@body('Parse_message')?[appsetting('MessageRowKeyField')]",
                  null
                ]
              }
            },
            {
              "not": {
                "equals": [
                  "@string(body('Parse_message')?[appsetting('MessageRowKeyField')])",
                  ""
                ]
              }
            }
          ]
        },
        "actions": {
          "Upsert_message_entity": {
            "type": "ServiceProvider",
            "inputs": {
              "parameters": {
                "tableName": "@appsetting('MessageTableName')",
                "entity": {
                  "PartitionKey": "@{string(body('Parse_message')?[appsetting('MessagePartitionKeyField')])}",
                  "RowKey": "@{string(body('Parse_message')?[appsetting('MessageRowKeyField')])}",
                  "Payload": "@{string(body('Parse_message'))}",
                  "SourceMessageId": "@{coalesce(triggerBody()?['messageId'], triggerBody()?['messageid'], triggerBody()?['MessageId'])}",
                  "SourceCorrelationId": "@{coalesce(triggerBody()?['correlationId'], triggerBody()?['correlationid'], triggerBody()?['CorrelationId'])}",
                  "SourceEnqueuedAt": "@{coalesce(triggerBody()?['enqueuedTimeUtc'], triggerBody()?['enqueuedTime'], utcNow())}"
                }
              },
              "serviceProviderConfiguration": {
                "connectionName": "azureTables",
                "operationId": "upsertEntity",
                "serviceProviderId": "/serviceProviders/azureTables"
              },
              "retryPolicy": {
                "type": "exponential",
                "count": 4,
                "interval": "PT5S",
                "minimumInterval": "PT5S",
                "maximumInterval": "PT1M"
              }
            }
          }
        },
        "else": {
          "actions": {
            "Reject_invalid_message": {
              "type": "Terminate",
              "inputs": {
                "runStatus": "Failed",
                "runError": {
                  "code": "InvalidMessage",
                  "message": "The configured partition-key or row-key field is missing or blank."
                }
              }
            }
          }
        },
        "runAfter": {
          "Parse_message": [
            "Succeeded"
          ]
        }
      }
    },
    "outputs": {}
  },
  "kind": "Stateful"
}
